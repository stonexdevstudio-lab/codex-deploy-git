rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAdmin() {
      return request.auth != null;
    }

    match /siteConfig/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chatbot_leads/{document} {
      allow read: if isAdmin();
      allow write: if true; // Public can submit leads
    }

    match /userRoles/{email} {
      allow read: if request.auth != null && (request.auth.token.email.lower() == email.lower() || request.auth.token.email.lower() == 'sanjoobjayamohan@gmail.com');
      allow write: if request.auth != null && request.auth.token.email.lower() == 'sanjoobjayamohan@gmail.com';
    }
  }
}
