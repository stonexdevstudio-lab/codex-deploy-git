  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; line-height: 1.6; color: #334155; margin: 40px; }
    h1 { text-align: center; color: #4f46e5; font-size: 24pt; margin-bottom: 5px; font-weight: bold; }
    .subtitle { text-align: center; color: #64748b; font-size: 11pt; margin-bottom: 30px; }
    h2 { color: #1e293b; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin-top: 30px; font-size: 15pt; font-weight: bold; }
    .meta-table, .line-table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 20px; }
    .meta-table td { border: none; padding: 6px; vertical-align: top; font-size: 10pt; }
    .line-table th, .line-table td { border: 1px solid #cbd5e1; padding: 10px; text-align: left; font-size: 9.5pt; }
    .line-table th { background-color: #f8fafc; color: #1e293b; font-weight: bold; }
    .total-row { font-weight: bold; background-color: #f1f5f9; }
    .highlight { font-weight: bold; color: #4f46e5; }
    .terms-list { font-size: 9.5pt; padding-left: 20px; }
    .terms-list li { margin-bottom: 6px; }
    .bank-info { background-color: #f8fafc; border: 1px solid #e2e8f0; padding: 15px; border-radius: 8px; margin-top: 15px; }
    .bank-info table { width: 100%; border-collapse: collapse; }
    .bank-info td { padding: 4px; border: none; font-size: 9.5pt; }
  </style>
</head>
<body>
  <h1>SOFTWARE DEVELOPMENT INVOICE</h1>
  <p class="subtitle">STX-2026-07-001 &bull; Stonex Minerals & Logistics Group Modernization</p>

